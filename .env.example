# ============================================================
# TaxLens — Root .env.example
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# --- Database (Supabase or local PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://taxlens:taxlens@localhost:5432/taxlens

# --- Redis ---
# Use memory:// for local dev without Redis
REDIS_URL=memory://

# --- JWT ---
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# --- SePay (SHB transaction API) ---
SEPAY_API_URL=https://my.sepay.vn/userapi
SEPAY_API_TOKEN=your_sepay_api_token_here
SEPAY_WEBHOOK_API_KEY=your_sepay_webhook_api_key_here

# --- Mock external services ---
INVOICE_API_URL=http://localhost:8001/mock/invoice
CASE_API_URL=http://localhost:8001/mock/case

# --- LLM Provider (DeepSeek / OpenRouter) ---
# Leave empty to use deterministic demo agent (no external calls)
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_MODEL_PLANNER=deepseek/deepseek-chat
LLM_MODEL_SPECIALIST=deepseek/deepseek-chat
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=
DEEPSEEK_TEMPERATURE=0.1
DEEPSEEK_MESSAGE_TEMPERATURE=0.3
DEEPSEEK_PLANNER_THINKING_ENABLED=true

# --- Frontend (NEXT_PUBLIC_* vars) ---
TAXLENS_BACKEND_URL=http://127.0.0.1:8000
NEXT_PUBLIC_TAXLENS_WS_PORT=8000
TAXLENS_COOKIE_SECURE=false

# --- App ---
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
ENVIRONMENT=development
