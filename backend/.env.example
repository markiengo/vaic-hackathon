# ============================================================
# TaxLens Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# Generate JWT_SECRET with: openssl rand -hex 32
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://taxlens:taxlens@localhost:5432/taxlens

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT ---
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# --- SePay (SHB transaction API) ---
SEPAY_API_URL=https://my.sepay.vn/userapi
SEPAY_API_TOKEN=your_sepay_api_token_here
SEPAY_WEBHOOK_API_KEY=your_sepay_webhook_api_key_here

# --- Mock external services ---
INVOICE_API_URL=http://localhost:8001/mock/invoice
CASE_API_URL=http://localhost:8001/mock/case

# --- LLM Provider (DeepSeek) ---
# config.py (P4 infrastructure) uses LLM_* vars:
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-your_deepseek_api_key_here
LLM_MODEL_PLANNER=deepseek-v4-flash
LLM_MODEL_SPECIALIST=deepseek-v4-flash
# deepseek.py (P2 agent layer) uses DEEPSEEK_* / OPENROUTER_* vars:
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=
DEEPSEEK_TEMPERATURE=0.1
DEEPSEEK_MESSAGE_TEMPERATURE=0.3
DEEPSEEK_PLANNER_THINKING_ENABLED=true

# --- App ---
CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development
