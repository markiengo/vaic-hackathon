# Server-only URL used by the Next.js gateway. Browser code never calls this directly.
TAXLENS_BACKEND_URL=http://127.0.0.1:8000

# Browser WebSocket host is derived from the current hostname; override only when needed.
NEXT_PUBLIC_TAXLENS_WS_PORT=8000

# Keep true behind HTTPS. Local Docker Compose overrides this to false for http://localhost.
TAXLENS_COOKIE_SECURE=true
